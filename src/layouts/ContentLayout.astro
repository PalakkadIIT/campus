---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  image?: string;
}

const { title, description, eyebrow, image } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="bg-campus-mist">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-16">
        <div class="flex flex-col justify-center">
          {eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-campus-teal">{eyebrow}</p>}
          <h1 class="mt-3 text-4xl font-bold tracking-normal text-campus-ink sm:text-5xl">{title}</h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">{description}</p>
        </div>
        {
          image && (
            <img
              src={image}
              alt=""
              class="h-64 w-full rounded-lg object-cover shadow-soft lg:h-80"
              loading="eager"
            />
          )
        }
      </div>
    </header>
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
      <div class="content-prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
