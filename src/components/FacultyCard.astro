---
interface Props {
  name: string;
  role: string;
  department: string;
  email: string;
  image: string;
}

const { name, role, department, email, image } = Astro.props;
---

<article class="rounded-lg border border-slate-200 bg-white p-5 text-center shadow-sm">
  <img src={image} alt="" class="mx-auto h-24 w-24 rounded-full object-cover" loading="lazy" />
  <h3 class="mt-4 text-lg font-bold text-campus-ink">{name}</h3>
  <p class="mt-1 text-sm font-medium text-campus-teal">{role}</p>
  <p class="mt-2 text-sm text-slate-600">{department}</p>
  <a href={`mailto:${email}`} class="mt-3 inline-block text-sm font-medium text-campus-navy hover:text-campus-teal">{email}</a>
</article>
