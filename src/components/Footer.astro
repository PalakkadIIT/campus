---
const quickLinks = [
  { href: '/admissions/', label: 'Admissions' },
  { href: '/departments/', label: 'Departments' },
  
  
  { href: '/contact/', label: 'Contact' },
];
---

<footer class="bg-campus-navy text-white">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-3 lg:px-8">
    <div>
      <p class="text-lg font-bold">Indian Institute of Technology, Palakkad</p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        Nurturing Minds For a Better World
      </p>
    </div>
    <div>
      <p class="font-semibold">Quick links</p>
      <div class="mt-3 grid gap-2">
        {quickLinks.map((link) => <a href={link.href} class="text-sm text-slate-300 hover:text-white">{link.label}</a>)}
      </div>
    </div>
    <address class="not-italic">
      <p class="font-semibold">Contact</p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        Indian Institute of Technology Palakkad</br>
        Kanjikode | Palakkad</br>
        Kerala | Pin: 678623</br>
        Phone:  +91 491 209 2013/2001 (Office) | </br> +91 491 209 2035 (Academic Section) <br />
        Email: netadmin@iitpkd.ac.in
      </p>
    </address>
  </div>
  <div class="border-t border-white/10 px-4 py-4 text-center text-xs text-slate-400">
    © {new Date().getFullYear()} IIT Palakkad. All rights reserved.
  </div>
</footer>
