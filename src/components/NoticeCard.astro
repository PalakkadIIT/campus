---
interface Props {
  title: string;
  date: Date;
  category: string;
  important: boolean;
  href: string;
}

const { title, date, category, important, href } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('en', { dateStyle: 'medium' }).format(date);
---

<a href={href} class="block rounded-lg border border-slate-200 bg-white p-5 shadow-sm hover:border-campus-teal hover:shadow-soft">
  <div class="flex flex-wrap items-center gap-2">
    <span class="rounded-md bg-campus-mist px-2.5 py-1 text-xs font-semibold text-campus-teal">{category}</span>
    {important && <span class="rounded-md bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-800">Important</span>}
  </div>
  <h3 class="mt-4 text-lg font-bold text-campus-ink">{title}</h3>
  <time datetime={date.toISOString()} class="mt-3 block text-sm text-slate-600">{formattedDate}</time>
</a>
