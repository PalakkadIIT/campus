---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="text-sm font-semibold uppercase tracking-wide text-campus-teal">{eyebrow}</p>}
  <h2 class="mt-2 text-3xl font-bold tracking-normal text-campus-ink sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-700">{description}</p>}
</div>
