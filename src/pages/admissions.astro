---
import { getEntry, render } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';

const page = await getEntry('pages', 'admissions');
if (!page) {
  throw new Error('Admissions page content is missing.');
}
const { Content } = await render(page);
---

<ContentLayout title={page.data.title} description={page.data.description} eyebrow="Admissions">
  <Content />
</ContentLayout>
