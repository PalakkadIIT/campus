---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import NoticeCard from '../../components/NoticeCard.astro';

const notices = (await getCollection('notices')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Notices" description="Latest official notices and announcements from North Valley College.">
  <section class="bg-campus-mist">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <SectionTitle eyebrow="Updates" title="Notices" description="Important college updates are stored as Markdown files." />
    </div>
  </section>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-4">
      {
        notices.map((notice) => (
          <NoticeCard
            title={notice.data.title}
            date={notice.data.date}
            category={notice.data.category}
            important={notice.data.important}
            href={`/notices/${notice.slug}/`}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
