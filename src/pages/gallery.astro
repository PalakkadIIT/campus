---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import gallery from '../content/data/gallery.json';
---

<BaseLayout title="Gallery" description="Campus gallery with local placeholder images for North Valley College.">
  <section class="bg-campus-mist">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <SectionTitle eyebrow="Gallery" title="Campus gallery" description="Image entries are maintained in JSON and use local files from public/images." />
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        gallery.map((item) => (
          <figure class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
            <img src={item.image} alt="" class="h-56 w-full object-cover" loading="lazy" />
            <figcaption class="p-5">
              <p class="text-xs font-semibold uppercase tracking-wide text-campus-teal">{item.category}</p>
              <h2 class="mt-2 text-lg font-bold text-campus-ink">{item.title}</h2>
              <p class="mt-2 text-sm leading-6 text-slate-600">{item.description}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>
</BaseLayout>
