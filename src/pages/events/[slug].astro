---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const formattedDate = new Intl.DateTimeFormat('en', { dateStyle: 'full' }).format(event.data.date);
---

<ContentLayout title={event.data.title} description={`${event.data.title} at ${event.data.location} on ${formattedDate}.`} eyebrow="Event" image={event.data.image}>
  <p class="font-semibold text-campus-teal">
    <time datetime={event.data.date.toISOString()}>{formattedDate}</time> · {event.data.location}
  </p>
  <Content />
</ContentLayout>
