---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import FacultyCard from '../../components/FacultyCard.astro';
import faculty from '../../content/data/faculty.json';
---

<BaseLayout title="Faculty" description="Faculty members and academic staff at IIT Palakkad.">
  <section class="bg-campus-mist">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
      <SectionTitle eyebrow="People" title="Faculty" description="Faculty profiles are maintained in a JSON file for quick updates." />
    </div>
  </section>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {faculty.map((member) => <FacultyCard {...member} />)}
    </div>
  </section>
</BaseLayout>
